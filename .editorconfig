# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8

end_of_line = lf
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

# Tab indentation (no size specified)
[Makefile]
indent_style = tab

# 2 space indentation
[*.{hcl, tf, tfconfig, tfvars, yml, yaml, json, tpl}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# 4 space indentation
[*.{md, txt}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

# 5 Shell scripts
[*.sh]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# 6 Dockerfiles
[Dockerfile]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
