server {
    listen 80;

    # Page de test visible depuis le navigateur
    location / {
        return 200 'LAB_KVM nginx - monitored by Datadog\n';
        add_header Content-Type text/plain;
    }

    # Endpoint consulté par l'agent Datadog pour les métriques nginx
    # (connexions actives, requêtes/s, etc.)
    location /nginx_status {
        stub_status on;
        allow 172.31.0.0/16;   # réseau Docker interne
        deny all;
    }
}
