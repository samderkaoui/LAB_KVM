services:

  # ──────────────────────────────────────────────
  # Service monitoré : nginx
  # ──────────────────────────────────────────────
  nginx:
    image: nginx:alpine
    container_name: nginx
    restart: unless-stopped
    ports:
      - "8080:80"
    volumes:
      - /var/datadog/nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    labels:
      com.datadoghq.ad.check_names: '["nginx"]'
      com.datadoghq.ad.init_configs: '[{}]'
      com.datadoghq.ad.instances: '[{"nginx_status_url": "http://%%host%%/nginx_status"}]'

  # ──────────────────────────────────────────────
  # Agent Datadog
  # ──────────────────────────────────────────────
  datadog-agent:
    image: registry.datadoghq.com/agent:7
    container_name: dd-agent
    restart: unless-stopped
    # Accès au namespace PID de l'hôte : CPU, mémoire, réseau, disque de la VM
    pid: host
    environment:
      DD_API_KEY: "{{ datadog_api_key }}"
      DD_SITE: "{{ datadog_site }}"
      DD_TAGS: "{{ datadog_tags | join(' ') }}"
      DD_ENV: dev
      # Hostname de la VM (sans ça l'agent prend le nom du container)
      DD_HOSTNAME: "{{ ansible_hostname }}"

      # ── APM ──────────────────────────────────────
      DD_APM_ENABLED: "true"
      DD_APM_NON_LOCAL_TRAFFIC: "true"
      # Socket Unix pour APM (plus performant que TCP)
      DD_APM_RECEIVER_SOCKET: /var/run/datadog/apm.socket

      # ── DogStatsD ─────────────────────────────────
      DD_DOGSTATSD_NON_LOCAL_TRAFFIC: "true"
      DD_DOGSTATSD_SOCKET: /var/run/datadog/dsd.socket

      # ── Logs ──────────────────────────────────────
      DD_LOGS_ENABLED: "true"
      DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL: "true"
      DD_LOGS_CONFIG_AUTO_MULTI_LINE_DETECTION: "true"
      DD_CONTAINER_EXCLUDE_LOGS: "name:dd-agent"
    volumes:
      # Hostname de la VM
      - /etc/hostname:/etc/hostname:ro
      # Socket Docker : autodiscovery + métriques containers
      - /var/run/docker.sock:/var/run/docker.sock:ro
      # Sockets APM et DogStatsD partagés avec les applis
      - /var/run/datadog:/var/run/datadog
      # Logs containers bruts
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      # Fichiers de position des logs (reprise après redémarrage)
      - /opt/datadog-agent/run:/opt/datadog-agent/run:rw
      # Métriques système de l'hôte
      - /proc/:/host/proc/:ro
      - /sys/fs/cgroup/:/host/sys/fs/cgroup:ro
      - /run/containerd:/run/containerd:ro
      # Checks custom (nginx en backup de l'autodiscovery)
      - /var/datadog/agent/conf.d:/etc/datadog-agent/conf.d:ro
    depends_on:
      - nginx
