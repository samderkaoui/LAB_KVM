# ── Storage ────────────────────────────────────────────────────────────────────
# Raft (intégré) : pas de dépendance externe, snapshots natifs
storage "raft" {
  path    = "/vault/data"
  node_id = "vault-node-1"
}

# ── Listener ───────────────────────────────────────────────────────────────────
listener "tcp" {
  address         = "0.0.0.0:8200"
  cluster_address = "0.0.0.0:8201"

  # TLS désactivé pour démarrer (homelab).
  # Pour activer TLS → remplacer par tls_cert_file / tls_key_file
  tls_disable = true
}

# ── UI ─────────────────────────────────────────────────────────────────────────
ui = true

# ── Cluster ────────────────────────────────────────────────────────────────────
cluster_name = "vault-homelab"

# ── API & Cluster addr ─────────────────────────────────────────────────────────
api_addr     = "http://{{ ansible_default_ipv4.address }}:8200"
cluster_addr = "https://{{ ansible_default_ipv4.address }}:8201"

# ── Logs ───────────────────────────────────────────────────────────────────────
log_level  = "info"
log_format = "json"

# ── Telemetry (optionnel - compatible Prometheus) ──────────────────────────────
# Décommenter si tu veux scraper les métriques
# telemetry {
#   prometheus_retention_time = "30s"
#   disable_hostname          = true
# }
