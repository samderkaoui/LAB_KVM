services:

  traefik:
    image: traefik:latest
    container_name: traefik
    restart: unless-stopped
    extra_hosts:
      - "gitlab.sam.com:172.30.0.6"
      - "keycloak.sam.com:172.30.0.6"
    command:
      - "--api.insecure=true"                        # Dashboard Traefik sur :8081
      - "--providers.docker.network=gitlab-network"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      # Redirection HTTP → HTTPS globale
      - "--entrypoints.web.http.redirections.entrypoint.to=websecure"
      - "--entrypoints.web.http.redirections.entrypoint.scheme=https"
      # TLS avec certificats self-signed (fichier)
      - "--providers.file.filename=/etc/traefik/tls.yml"
      - "--log.level=INFO"
    environment:
      - DOCKER_API_VERSION=1.54
    ports:
      - "80:80"
      - "443:443"
      - "8081:8080"     # Dashboard Traefik
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/gitll/traefik/tls.yml:/etc/traefik/tls.yml:ro
      - /var/gitll/certs:/certs:ro
    networks:
      gitlab:
        ipv4_address: 172.30.0.6

  web:
    image: 'gitlab/gitlab-ce:latest'
    restart: always
    hostname: 'gitlab.sam.com'
    container_name: gitlab-ce
    extra_hosts:
      - "keycloak.sam.com:172.30.0.6"
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.gitlab.rule=Host(`gitlab.sam.com`)"
      - "traefik.http.routers.gitlab.entrypoints=websecure"
      - "traefik.http.routers.gitlab.tls=true"
      - "traefik.http.services.gitlab.loadbalancer.server.port=80"
    environment:
      GITLAB_OMNIBUS_CONFIG: |
        external_url 'https://gitlab.sam.com'
        nginx['listen_port'] = 80
        nginx['listen_https'] = false
        nginx['proxy_set_headers'] = {
          "X-Forwarded-Proto" => "https",
          "X-Forwarded-Ssl" => "on"
        }
        gitlab_rails['omniauth_enabled'] = true
        gitlab_rails['omniauth_allow_single_sign_on'] = ['openid_connect']
        gitlab_rails['omniauth_block_auto_created_users'] = false
        gitlab_rails['omniauth_auto_link_user'] = ['openid_connect']
        gitlab_rails['omniauth_providers'] = [
          {
            name: 'openid_connect',
            label: 'Keycloak SSO',
            args: {
              name: 'openid_connect',
              scope: ['openid', 'profile', 'email', 'roles'],
              response_type: 'code',
              issuer: 'https://keycloak.sam.com/realms/homelab',
              client_auth_method: 'query',
              discovery: true,
              uid_field: 'preferred_username',
              client_options: {
                identifier: 'gitlab',
                secret: 'xxxxxx',
                redirect_uri: 'https://gitlab.sam.com/users/auth/openid_connect/callback'
              }
            }
          }
        ]
    volumes:
      - '/var/gitll/config:/etc/gitlab'
      - '/var/gitll/logs:/var/log/gitlab'
      - '/var/gitll/data:/var/opt/gitlab'
      # Cert Keycloak trusted par GitLab pour valider le token
      - '/var/gitll/certs/gitkc.crt:/etc/gitlab/trusted-certs/gitkc.crt'
    networks:
      gitlab:
        ipv4_address: 172.30.0.2

  gitlab-runner:
    image: gitlab/gitlab-runner:alpine
    container_name: gitlab-runner
    restart: always
    depends_on:
      - web
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - '/var/gitll/gitlab-runner:/etc/gitlab-runner'
    networks:
      gitlab:
        ipv4_address: 172.30.0.3
    extra_hosts:
      - "gitlab.sam.com:172.30.0.6"
      - "keycloak.sam.com:172.30.0.6"

  postgres:
    image: postgres:16
    container_name: keycloak_db
    restart: unless-stopped
    environment:
      POSTGRES_DB: keycloak
      POSTGRES_USER: keycloak
      POSTGRES_PASSWORD: changeme
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      gitlab:
        ipv4_address: 172.30.0.4
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U keycloak"]
      interval: 10s
      timeout: 5s
      retries: 5

  keycloak:
    image: quay.io/keycloak/keycloak:26.1
    container_name: keycloak
    restart: unless-stopped
    command: start-dev
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.keycloak.rule=Host(`keycloak.sam.com`)"
      - "traefik.http.routers.keycloak.entrypoints=websecure"
      - "traefik.http.routers.keycloak.tls=true"
      - "traefik.http.services.keycloak.loadbalancer.server.port=8080"
    environment:
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://postgres:5432/keycloak
      KC_DB_USERNAME: keycloak
      KC_DB_PASSWORD: changeme
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: changeme
      KC_HOSTNAME: https://keycloak.sam.com
      KC_HOSTNAME_STRICT: false
      KC_HTTP_ENABLED: true
      KC_HTTP_PORT: 8080
      KC_PROXY_HEADERS: xforwarded
      KC_LOG_LEVEL: INFO
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      gitlab:
        ipv4_address: 172.30.0.5

volumes:
  postgres_data:

networks:
  gitlab:
    name: gitlab-network
    driver: bridge
    ipam:
      config:
        - subnet: 172.30.0.0/16
          gateway: 172.30.0.1
